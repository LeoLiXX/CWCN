<resources>
    <style name="Theme.CWCN" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cwcn_primary</item>
        <item name="colorPrimaryVariant">@color/cwcn_primary_variant</item>
        <item name="colorSecondary">@color/cwcn_secondary</item>
        <item name="colorSecondaryVariant">@color/cwcn_secondary_variant</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/cwcn_screen_background</item>
        <item name="android:windowBackground">@color/cwcn_screen_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.CWCN.Splash" parent="Theme.CWCN">
        <item name="android:windowBackground">@drawable/splash_window_background</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
