<resources>
    <style name="TextAppearance.CWCN.BottomNav.Active" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.CWCN.BottomNav.Inactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.CWCN.CompactActionButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/cwcn_secondary_button_background</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/cwcn_title</item>
        <item name="android:textSize">10sp</item>
        <item name="android:minHeight">0dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">7dp</item>
        <item name="android:paddingBottom">7dp</item>
    </style>
</resources>
