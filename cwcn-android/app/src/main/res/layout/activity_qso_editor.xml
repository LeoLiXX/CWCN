<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/qso_editor_back_cd"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_back"
            android:tint="@color/cwcn_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/qso_editor_title_default"
                android:textColor="@color/cwcn_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/editorModeChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/operate_chip_background"
            android:gravity="center"
            android:minHeight="22dp"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textColor="@color/cwcn_body"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/seedSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/editorStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/cwcn_body"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_time"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/qsoTimeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/qso_editor_time_format_hint"
                    android:inputType="datetime"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <TextView
                    android:id="@+id/qsoTimeHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_callsigns"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/remoteCallsignEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/qso_editor_hint_remote_callsign"
                    android:inputType="textCapCharacters"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/stationCallsignEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/qso_editor_hint_station_callsign"
                    android:inputType="textCapCharacters"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_radio"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/frequencyEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/qso_editor_hint_frequency_hz"
                    android:inputType="number"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <TextView
                    android:id="@+id/bandSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_report"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/rstSentEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/qso_editor_hint_rst_sent"
                        android:inputType="textCapCharacters"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <EditText
                        android:id="@+id/rstRcvdEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/qso_editor_hint_rst_rcvd"
                        android:inputType="textCapCharacters"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_profile"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/nameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/qso_editor_hint_name"
                    android:inputType="textPersonName"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/qthEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/qso_editor_hint_qth"
                    android:inputType="textCapWords"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_grid"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/remoteGridEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/qso_editor_hint_remote_grid"
                        android:inputType="textCapCharacters"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <EditText
                        android:id="@+id/stationGridEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/qso_editor_hint_station_grid"
                        android:inputType="textCapCharacters"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />
                </LinearLayout>

                <TextView
                    android:id="@+id/distanceSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/qso_editor_section_comment"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/commentEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:gravity="top|start"
                    android:hint="@string/qso_editor_hint_comment"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="4"
                    android:minLines="3"
                    android:padding="12dp"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <CheckBox
                    android:id="@+id/manualConfirmedCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:buttonTint="@color/cwcn_accent"
                    android:text="@string/qso_editor_manual_confirmed"
                    android:textColor="@color/cwcn_body"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/actionStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/formal_bottom_nav_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/resetButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/qso_editor_action_reset" />

        <Button
            android:id="@+id/openLogbookButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/qso_editor_action_open_logbook" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1.2"
            android:text="@string/qso_editor_action_save" />
    </LinearLayout>

</LinearLayout>
