<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/rig_setup_title_config"
                android:textColor="@color/cwcn_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cwcn_accent"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/operate_chip_background"
                android:contentDescription="@string/rig_setup_back"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_ui_back"
                android:tint="@color/cwcn_body" />
        </LinearLayout>

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/rig_setup_subtitle_config"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/usbAttachStatusPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_usb_attach_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/usbAttachStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/connectionGuidePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_connection_guide_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/connectionGuideText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/readinessSummaryPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_readiness_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/readinessSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_current_path_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/profileSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:padding="10dp" />

            <Button
                android:id="@+id/saveSelectedProfileButton"
                style="@style/Widget.CWCN.CompactActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/rig_setup_select_current_path" />

            <TextView
                android:id="@+id/selectedProfileStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profileConfigPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_profile_config_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/rig_setup_profile_config_hint"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/usbConfigGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/rig_setup_usb_config_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/usbKeyLineSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/usbPreferredDeviceNameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_usb_preferred_device_hint"
                    android:inputType="text"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <Spinner
                    android:id="@+id/usbDeviceSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/requestUsbKeyerPermissionButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/rig_setup_usb_keyer_request_permission" />

                <Button
                    android:id="@+id/testUsbKeyerPulseButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_test_usb_keyer_pulse" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/sendUsbKeyerTestTextButton"
                        style="@style/Widget.CWCN.CompactActionButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/rig_setup_action_send_usb_vvv" />

                    <Button
                        android:id="@+id/stopUsbKeyerTextButton"
                        style="@style/Widget.CWCN.CompactActionButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="@string/rig_setup_action_stop" />
                </LinearLayout>

                <TextView
                    android:id="@+id/usbKeyerStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/cwcn_body"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/serialCatConfigGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/serialCatProtocolLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/rig_setup_serial_cat_protocol_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatProtocolSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/serialCatBaudRateEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_baud_rate_hint"
                    android:inputType="number"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <TextView
                    android:id="@+id/serialCatKeyLineLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_key_line_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatKeyLineSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/serialCatKeyingPolarityLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_keying_polarity_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatKeyingPolaritySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <CheckBox
                    android:id="@+id/serialCatAssertRtsCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_assert_rts" />

                <CheckBox
                    android:id="@+id/serialCatAssertDtrCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/rig_setup_assert_dtr" />

                <TextView
                    android:id="@+id/serialCatPortPickerLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_detected_cat_ports_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatPortSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/serialCatKeyingPortLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_detected_keying_ports_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatKeyingPortSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/serialCatPortHintEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_cat_port_hint"
                    android:inputType="text"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/serialCatCivAddressEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_civ_address_hint"
                    android:inputType="textCapCharacters"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <Button
                    android:id="@+id/requestSerialCatPermissionButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/rig_setup_action_request_serial_cat_permission" />

                <Button
                    android:id="@+id/testSerialCatConnectionButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_test_serial_cat_connection" />

                <Button
                    android:id="@+id/testSerialCatPttButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_test_serial_cat_ptt" />

                <Button
                    android:id="@+id/testSerialCatKeyingButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_test_serial_keying_pulse" />

                <Button
                    android:id="@+id/holdSerialCatKeyingButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_test_serial_keying_hold" />

                <Button
                    android:id="@+id/openCloseSerialCatKeyingPortButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_test_serial_keying_open_close" />

                <Button
                    android:id="@+id/runSerialCatKeyingSweepButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_run_serial_keying_sweep" />

                <TextView
                    android:id="@+id/serialCatTimingLabLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/rig_setup_timing_lab_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatTimingAssertOrderSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <Spinner
                    android:id="@+id/serialCatTimingReleaseOrderSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/serialCatTimingPreDelayEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/rig_setup_hint_pre_delay_ms"
                        android:inputType="number"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <EditText
                        android:id="@+id/serialCatTimingHoldEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/rig_setup_hint_hold_ms"
                        android:inputType="number"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/serialCatTimingInterLineGapEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/rig_setup_hint_inter_line_gap_ms"
                        android:inputType="number"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <EditText
                        android:id="@+id/serialCatTimingReleaseGapEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/rig_setup_hint_release_gap_ms"
                        android:inputType="number"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />
                </LinearLayout>

                <Button
                    android:id="@+id/runSerialCatTimingLabButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_run_timing_lab" />

                <TextView
                    android:id="@+id/serialCatShortPulseLabLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/rig_setup_short_pulse_lab_title"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/serialCatShortPulsePresetSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/serialCatShortPulsePreDelayEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/rig_setup_hint_pre_delay_ms"
                        android:inputType="number"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <EditText
                        android:id="@+id/serialCatShortPulseTailHoldEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="@string/rig_setup_hint_tail_hold_ms"
                        android:inputType="number"
                        android:padding="12dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />
                </LinearLayout>

                <EditText
                    android:id="@+id/serialCatShortPulseReleaseGapEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_hint_extra_release_gap_ms"
                    android:inputType="number"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <Button
                    android:id="@+id/runSerialCatShortPulseLabButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/rig_setup_action_run_short_pulse_lab" />

                <TextView
                    android:id="@+id/serialCatProbeStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/networkCatConfigGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/networkCatProtocolLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/rig_setup_transport_network_cat"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/networkCatProtocolSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:padding="12dp" />

                <EditText
                    android:id="@+id/networkHostEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_hint_host_or_ip"
                    android:inputType="textUri"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/networkPortEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_hint_network_port"
                    android:inputType="number"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <Button
                    android:id="@+id/testNetworkCatConnectionButton"
                    style="@style/Widget.CWCN.CompactActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/rig_setup_action_test_network_cat_connection" />

                <TextView
                    android:id="@+id/networkCatProbeStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bluetoothConfigGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/rig_setup_transport_bluetooth_serial"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/bluetoothDeviceHintEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/rig_setup_hint_bluetooth_device"
                    android:inputType="text"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

        <TextView
            android:id="@+id/audioVoxConfigHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/rig_setup_audio_vox_config_hint"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="13sp" />

            <Button
                android:id="@+id/saveProfileConfigButton"
                style="@style/Widget.CWCN.CompactActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/rig_setup_action_save_profile_config" />

            <Button
                android:id="@+id/resetProfileConfigButton"
                style="@style/Widget.CWCN.CompactActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/rig_setup_action_reset_profile_config" />

            <TextView
                android:id="@+id/profileConfigStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/transportSummaryPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_transport_summary_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/transportSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profileSummaryPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_profile_summary_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nextStepPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rig_setup_next_step_panel_title"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nextStepText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
