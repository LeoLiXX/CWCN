<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/tx_template_back"
            android:padding="5dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_back"
            android:tint="@color/cwcn_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tx_template_editor_title"
                android:textColor="@color/cwcn_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subtitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/resetButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="@string/tx_template_editor_reset"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_clear"
            android:tint="@color/cwcn_body" />

        <ImageButton
            android:id="@+id/saveButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="@string/tx_template_editor_save"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_edit"
            android:tint="@color/cwcn_body" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/editorStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cwcn_body"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tx_template_editor_field_name"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/templateNameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="@string/tx_template_editor_field_name_hint"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tx_template_editor_field_body"
                    android:textColor="@color/cwcn_title"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/templateBodyEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:fontFamily="monospace"
                    android:gravity="top|start"
                    android:hint="@string/tx_template_editor_field_body_hint"
                    android:inputType="textCapCharacters|textMultiLine"
                    android:minLines="6"
                    android:padding="12dp"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_panel_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/placeholderSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cwcn_body"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/templatePreviewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
