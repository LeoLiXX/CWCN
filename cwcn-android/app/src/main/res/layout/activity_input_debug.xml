<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bootstrap_title"
            android:textColor="@color/cwcn_title"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/bootstrap_subtitle"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/versionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/cwcn_accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bootstrap_overview_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/summaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cwcn_body"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/permissionHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cwcn_accent"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/inputControlsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/input_section_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/inputSourceSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bootstrap_field_background"
                android:padding="12dp" />

            <TextView
                android:id="@+id/fixtureScenarioLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Fixture Scenario"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/fixtureScenarioSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:padding="12dp" />

            <TextView
                android:id="@+id/localFileLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Local Replay File"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/localFileStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:lineSpacingExtra="3dp"
                android:padding="12dp"
                android:text="No file selected."
                android:textColor="@color/cwcn_body"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/selectLocalFileButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Choose Local Audio File"
                android:visibility="gone" />

            <TextView
                android:id="@+id/preferredToneLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Preferred CW Tone (Hz)"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/preferredToneFrequencyEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="650"
                android:inputType="number"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/applyPreferredToneButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apply Tone" />

                <Button
                    android:id="@+id/useFixtureToneButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Use Fixture Tone" />
            </LinearLayout>

            <TextView
                android:id="@+id/selectedSourceStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/fixtureEvaluationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bootstrap_field_background"
                android:padding="12dp"
                android:text="No fixture evaluation yet."
                android:textColor="@color/cwcn_body"
                android:textSize="13sp" />

            <Button
                android:id="@+id/toggleDebugDetailsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Show Detailed Panels" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/refreshStatusButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/action_refresh_status" />

                <Button
                    android:id="@+id/requestPermissionButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/action_request_permission" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rxFocusPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RX Focus"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rxFocusStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bootstrap_field_background"
                android:lineSpacingExtra="3dp"
                android:padding="12dp"
                android:textColor="@color/cwcn_body"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/rxFocusDecodeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rxFocusSpectrumLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Spectrum Preview"
                android:textColor="@color/cwcn_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <org.bi9clt.cwcn.ui.debug.AudioSpectrumView
                android:id="@+id/rxFocusSpectrumView"
                android:layout_width="match_parent"
                android:layout_height="144dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bootstrap_field_background"
                android:padding="8dp" />

            <TextView
                android:id="@+id/rxFocusSpectrumSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/rxFocusStartCaptureButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/action_start_capture" />

                <Button
                    android:id="@+id/rxFocusStopCaptureButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/action_stop_capture" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deviceStatusPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/device_status_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/microphoneStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/bluetoothStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/usbStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/transportRegistryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/adifPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adif_section_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adifFieldMapText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/adifPreviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <Button
                android:id="@+id/exportAdifButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Export ADIF" />

            <TextView
                android:id="@+id/adifExportStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/qsoPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/qso_section_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/qsoPhaseText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/qsoDraftText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/qsoEditorHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Manual corrections override live decode until reset."
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/stationCallsignEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="Station callsign"
                android:inputType="textCapCharacters"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/remoteCallsignEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="Remote callsign"
                android:inputType="textCapCharacters"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/rstSentEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="RST sent"
                    android:inputType="textCapCharacters"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/rstRcvdEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="RST rcvd"
                    android:inputType="textCapCharacters"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <EditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="Name"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/qthEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="QTH"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/applyDraftEditsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apply Edits" />

                <Button
                    android:id="@+id/resetDraftEditsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Reset Manual" />
            </LinearLayout>

            <TextView
                android:id="@+id/qsoEditorStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/callsignCandidatesTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Callsign candidates"
                android:textColor="@color/cwcn_body"
                android:textSize="13sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/callsignCandidateContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/callsignCandidateStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/qsoReadinessText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lastQsoEventText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/saveDraftButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save Draft" />

                <Button
                    android:id="@+id/confirmLogButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Confirm Log" />
            </LinearLayout>

            <Button
                android:id="@+id/openQsoEditorButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Open QSO Editor" />

            <TextView
                android:id="@+id/qsoStorageStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/interpreterPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/interpreter_section_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/interpreterRawText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/interpreterNormalizedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/interpreterCallsignsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/interpreterHintsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/lastInterpreterEventText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/decoderPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/decoder_section_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/decoderStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/decoderEventStatsText"
