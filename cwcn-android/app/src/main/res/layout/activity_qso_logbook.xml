<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/exportButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="局域网导出"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_download"
            android:tint="@color/cwcn_body" />

        <ImageButton
            android:id="@+id/shareButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="分享文本"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_share"
            android:tint="@color/cwcn_body" />

        <ImageButton
            android:id="@+id/newButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="新建记录"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_add"
            android:tint="@color/cwcn_body" />

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/logbook_search_field_background"
            android:gravity="center_vertical"
            android:hint="呼号搜索"
            android:imeOptions="actionDone"
            android:inputType="textCapCharacters"
            android:maxLines="1"
            android:minHeight="34dp"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:textColor="@color/cwcn_body"
            android:textColorHint="@color/cwcn_subtitle"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/viewModeButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="切换显示模式"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_view_compact"
            android:tint="@color/cwcn_body" />

        <ImageButton
            android:id="@+id/filterButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/logbook_toolbar_button_background"
            android:contentDescription="高级筛选"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ui_sliders"
            android:tint="@color/cwcn_body" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/logRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="5dp"
            android:paddingTop="2dp"
            android:paddingEnd="5dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/emptyStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="暂无 QSO 记录"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="12sp"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/formal_bottom_nav_background"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        app:itemBackground="@drawable/formal_bottom_nav_item_background"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/formal_bottom_nav_item_colors"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextAppearanceActive="@style/TextAppearance.CWCN.BottomNav.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.CWCN.BottomNav.Inactive"
        app:itemTextColor="@color/formal_bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/formal_bottom_nav_menu" />

</LinearLayout>
