<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QSO Logbook"
            android:textColor="@color/cwcn_title"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Browse confirmed logs and load one back into the editor."
            android:textColor="@color/cwcn_subtitle"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back" />

            <Button
                android:id="@+id/reloadButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Reload Logs" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Filter &amp; Sort"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/callsignFilterEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="Filter by callsign"
                android:inputType="textCapCharacters"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/fromDateFilterEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="From YYYYMMDD"
                    android:inputType="date"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/toDateFilterEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="To YYYYMMDD"
                    android:inputType="date"
                    android:padding="12dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/reviewOnlyCheckBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Review only"
                android:textColor="@color/cwcn_body" />

            <Spinner
                android:id="@+id/sortOrderSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bootstrap_field_background"
                android:padding="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/applyFilterButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apply" />

                <Button
                    android:id="@+id/clearFilterButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Clear" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log List"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/logSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/logButtonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selected Log Detail"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/selectedLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/selectedLogRawText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/selectedLogReviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/loadIntoEditorButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Re-edit" />

                <Button
                    android:id="@+id/toggleReviewButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Toggle Review" />
            </LinearLayout>

            <Button
                android:id="@+id/deleteLogButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Delete Selected Log" />

            <TextView
                android:id="@+id/actionStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
