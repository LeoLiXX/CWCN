<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="设置"
                android:textColor="@color/cwcn_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cwcn_accent"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/operate_chip_background"
                android:contentDescription="Back"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_ui_back"
                android:tint="@color/cwcn_body" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="台站资料"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/stationInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Station help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/stationProfileText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="1"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/operatingDefaultsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />

            <EditText
                android:id="@+id/stationCallsignEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="我的呼号"
                android:inputType="textCapCharacters"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/operatorNameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="操作员姓名"
                android:inputType="textPersonName"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/qthEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="QTH / 所在地"
                android:inputType="textCapWords"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/maidenheadGridEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="梅登海格网格，例如 PM01"
                android:inputType="textCapCharacters"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/rigDescriptionEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="RIG 模板变量，例如 IC-705 5W"
                android:inputType="textCapSentences"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/antennaDescriptionEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="ANT 模板变量，例如 EFHW"
                android:inputType="textCapSentences"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/weatherDescriptionEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="WX 模板变量，例如 SUNNY 28C"
                android:inputType="textCapSentences"
                android:padding="8dp"
                android:singleLine="true"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <TextView
                android:id="@+id/stationProfileStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="电台链路"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/radioRouteInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Radio route help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/radioRouteText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />

            <Button
                android:id="@+id/openRigSetupButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/operate_chip_background"
                android:minHeight="0dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:text="打开 Rig Setup"
                android:textAllCaps="false"
                android:textColor="@color/cwcn_body"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="无电台兜底"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/routeFallbackInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Fallback help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/routeFallbackText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />

            <Spinner
                android:id="@+id/routeFallbackModeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/routeFallbackStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CAT 与键控"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/catKeyingInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="CAT and keying help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/catKeyingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/catKeyingHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/routeSettingsScopeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/cwcn_body"
                android:textSize="10sp" />

            <LinearLayout
                android:id="@+id/serialRouteSettingsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="串口 CAT"
                    android:textColor="@color/cwcn_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/serialCatPortHintEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="串口端口提示"
                    android:inputType="text"
                    android:padding="8dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/serialCatBaudRateEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="波特率"
                        android:inputType="number"
                        android:padding="10dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <Spinner
                        android:id="@+id/serialCatKeyLineSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/serialCatKeyingPortHintEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="键控端口提示"
                        android:inputType="text"
                        android:padding="8dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />

                    <Spinner
                        android:id="@+id/serialCatKeyingPolaritySpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <EditText
                    android:id="@+id/serialCatCivAddressEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="CI-V 地址（十六进制）"
                    android:inputType="textCapCharacters"
                    android:padding="10dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/networkRouteSettingsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="网络 CAT"
                    android:textColor="@color/cwcn_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/networkHostEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="主机"
                    android:inputType="textUri"
                    android:padding="8dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/networkPortEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="端口"
                    android:inputType="number"
                    android:padding="8dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/usbRouteSettingsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="USB 键控"
                    android:textColor="@color/cwcn_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/usbKeyLineSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/usbPreferredDeviceNameEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bootstrap_field_background"
                        android:hint="偏好 USB 设备"
                        android:inputType="text"
                        android:padding="8dp"
                        android:singleLine="true"
                        android:textColor="@color/cwcn_body"
                        android:textColorHint="@color/cwcn_subtitle" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/usbDeviceSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/requestUsbKeyerPermissionButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/operate_chip_background"
                    android:minHeight="0dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:text="申请 USB 权限"
                    android:textAllCaps="false"
                    android:textColor="@color/cwcn_body"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/usbRouteStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/routeSettingsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CW 默认值"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/cwDefaultsInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="CW defaults help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/cwDefaultsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/defaultWpmEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="WPM"
                    android:inputType="number"
                    android:padding="8dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />

                <EditText
                    android:id="@+id/defaultToneEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bootstrap_field_background"
                    android:hint="音调 Hz"
                    android:inputType="number"
                    android:padding="8dp"
                    android:singleLine="true"
                    android:textColor="@color/cwcn_body"
                    android:textColorHint="@color/cwcn_subtitle" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/rxInputModeSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <Spinner
                    android:id="@+id/rxToneModeSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1" />

                <Spinner
                    android:id="@+id/rxMicSourceModeSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/cwDefaultsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="发送模板"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/txTemplatesInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="TX templates help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/txTemplatesSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_body"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/templateCqEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="CQ 模板"
                android:inputType="textCapCharacters|textMultiLine"
                android:minLines="2"
                android:padding="8dp"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/templateCqDxEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="应答模板"
                android:inputType="textCapCharacters|textMultiLine"
                android:minLines="2"
                android:padding="8dp"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/templateQrzEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="设备信息模板"
                android:inputType="textCapCharacters|textMultiLine"
                android:minLines="2"
                android:padding="8dp"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <EditText
                android:id="@+id/templateTu73EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bootstrap_field_background"
                android:hint="收尾模板"
                android:inputType="textCapCharacters|textMultiLine"
                android:minLines="2"
                android:padding="8dp"
                android:textColor="@color/cwcn_body"
                android:textColorHint="@color/cwcn_subtitle" />

            <TextView
                android:id="@+id/txTemplatesStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="高级 / 开发"
                    android:textColor="@color/cwcn_title"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/developerInfoButton"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Developer help"
                    android:padding="2dp"
                    android:src="@drawable/ic_ui_info"
                    android:tint="@color/cwcn_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/developerModeStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />

            <Button
                android:id="@+id/toggleDeveloperModeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/operate_chip_background"
                android:minHeight="0dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:text="启用开发者模式"
                android:textAllCaps="false"
                android:textColor="@color/cwcn_body"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/developerToolsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开发者工具"
                android:textColor="@color/cwcn_title"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/developerToolsNoteText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="10sp" />

            <Button
                android:id="@+id/openDeveloperToolsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/operate_chip_background"
                android:minHeight="0dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:text="打开工具"
                android:textAllCaps="false"
                android:textColor="@color/cwcn_body"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
