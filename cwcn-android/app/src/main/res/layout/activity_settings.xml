<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/cwcn_title"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Configuration and advanced controls live here so Home and Operate can stay focused on radio work."
            android:textColor="@color/cwcn_subtitle"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/versionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/cwcn_accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Back" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Station And Operating"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stationProfileText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Radio And Audio"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rigSettingsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <Button
                android:id="@+id/openRigSetupButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Open Connect Radio" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced / Developer"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/developerModeStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <Button
                android:id="@+id/toggleDeveloperModeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Enable Developer Mode" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/developerToolsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Developer Tools"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/developerToolsNoteText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <Button
                android:id="@+id/openDeveloperToolsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Open Developer Tools" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
