<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:paddingEnd="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingTop="2dp"
            android:paddingEnd="2dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/statusMainText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cwcn_title"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusDetailText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="7sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/openRigSetupButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/operate_action_button_background"
                android:contentDescription="@string/operate_open_rig_setup_cd"
                android:padding="7dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_ui_settings"
                android:tint="@color/cwcn_subtitle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/operate_surface_background"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/operate_transcript_title"
                        android:textColor="@color/cwcn_title"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/sourceChipText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/operate_chip_active_background"
                        android:gravity="center"
                        android:paddingStart="6dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="2dp"
                        android:textColor="@color/cwcn_accent"
                        android:textSize="7sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/transcriptTimeModeChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/operate_chip_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="20dp"
                        android:paddingStart="6dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="2dp"
                        android:text="@string/operate_time_mode_utc"
                        android:textColor="@color/cwcn_body"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/clearTranscriptChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/operate_chip_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="20dp"
                        android:paddingStart="6dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="2dp"
                        android:text="@string/operate_transcript_clear"
                        android:textColor="@color/cwcn_body"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/callsignHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/operate_chip_background"
                    android:clickable="true"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:maxLines="1"
                    android:minHeight="22dp"
                    android:paddingStart="6dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="3dp"
                    android:textColor="@color/cwcn_accent"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <ScrollView
                    android:id="@+id/conversationScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fillViewport="true"
                    android:padding="0dp">

                    <LinearLayout
                        android:id="@+id/conversationList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="140dp"
                        android:orientation="vertical" />
                </ScrollView>

                <TextView
                    android:id="@+id/rxFootnoteText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/cwcn_subtitle"
                    android:textSize="9sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/operate_dock_background"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/operate_template_label"
                        android:textColor="@color/cwcn_subtitle"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/templateSelectorSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/operate_field_background"
                        android:minHeight="34dp" />

                    <TextView
                        android:id="@+id/templatePreviewText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/cwcn_subtitle"
                        android:textSize="8sp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dockStateRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/selectedTemplateChip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/cwcn_accent"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/txRouteChip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/cwcn_subtitle"
                                android:textSize="8sp" />

                            <TextView
                                android:id="@+id/txStageChip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/cwcn_subtitle"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/sqlQuickChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/operate_chip_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="20dp"
                        android:paddingStart="6dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="2dp"
                        android:textColor="@color/cwcn_body"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/operate_tx_input_title"
                        android:textColor="@color/cwcn_subtitle"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/txComposeEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/operate_field_background"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="@string/operate_tx_input_hint"
                        android:inputType="textCapCharacters|textMultiLine"
                        android:maxLines="2"
                        android:minLines="2"
                        android:padding="7dp"
                        android:textColor="@color/cwcn_title"
                        android:textColorHint="@color/cwcn_subtitle"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/clearComposeButton"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/operate_action_button_secondary_background"
                            android:contentDescription="@string/operate_tx_clear_cd"
                            android:padding="7dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_ui_clear"
                            android:tint="@color/cwcn_body" />

                        <ImageButton
                            android:id="@+id/resetTxButton"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/operate_action_button_secondary_background"
                            android:contentDescription="@string/operate_tx_reset_cd"
                            android:padding="7dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_ui_rewind"
                            android:tint="@color/cwcn_body" />

                        <ImageButton
                            android:id="@+id/repeatToggleButton"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/operate_action_button_secondary_background"
                            android:contentDescription="@string/operate_tx_repeat_cd"
                            android:padding="7dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_ui_repeat"
                            android:tint="@color/cwcn_body" />

                        <TextView
                            android:id="@+id/repeatIntervalChip"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/operate_chip_background"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:minWidth="42dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:text="@string/operate_tx_repeat_interval_value"
                            android:textColor="@color/cwcn_body"
                            android:textSize="8sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/sendTxButton"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/operate_action_button_primary_background"
                            android:contentDescription="@string/operate_tx_send_cd"
                            android:padding="7dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_ui_send"
                            android:tint="@color/cwcn_tx_line" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/txStatusRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/cwcn_subtitle"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/repeatCountdownText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/cwcn_subtitle"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/repeatCountdownProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="4dp"
                    android:max="1000"
                    android:progress="0"
                    android:progressTint="@color/cwcn_tx_line"
                    android:visibility="invisible" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/formal_bottom_nav_background"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:itemBackground="@drawable/formal_bottom_nav_item_background"
            app:itemIconSize="22dp"
            app:itemIconTint="@color/formal_bottom_nav_item_colors"
            app:itemRippleColor="@android:color/transparent"
            app:itemTextAppearanceActive="@style/TextAppearance.CWCN.BottomNav.Active"
            app:itemTextAppearanceInactive="@style/TextAppearance.CWCN.BottomNav.Inactive"
            app:itemTextColor="@color/formal_bottom_nav_item_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/formal_bottom_nav_menu" />
    </LinearLayout>

    <View
        android:id="@+id/overlayScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cwcn_overlay_scrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/overlayPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginStart="22dp"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="22dp"
        android:background="@drawable/operate_overlay_panel_background"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/overlayTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/cwcn_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/closeOverlayButton"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/operate_chip_background"
                android:contentDescription="@string/operate_overlay_close_cd"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_ui_clear"
                android:tint="@color/cwcn_accent" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlaySubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/chartOverlayContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/chartOverlayText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sqlOverlayContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/sqlLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/operate_sql_label"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="12sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/sqlSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="55" />

            <TextView
                android:id="@+id/wpmLabelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/operate_wpm_label"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="12sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/wpmSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="75"
                android:progress="15" />

            <TextView
                android:id="@+id/sqlOverlayText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/templateOverlayContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/overlayTemplateChipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <ImageButton
                    android:id="@+id/openTemplateLibraryButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/operate_chip_background"
                    android:contentDescription="@string/operate_open_template_library_cd"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_ui_edit"
                    android:tint="@color/cwcn_body" />
            </LinearLayout>

            <TextView
                android:id="@+id/templateOverlayText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sideRail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp"
        android:background="@drawable/operate_side_rail_background"
        android:orientation="vertical"
        android:padding="4dp">

        <LinearLayout
            android:id="@+id/sideRailButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/sideChartButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/operate_side_button_background"
                android:contentDescription="@string/operate_open_chart_overlay_cd"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/icon_side_chart"
                android:tint="@color/cwcn_title" />

            <ImageButton
                android:id="@+id/sideSqlButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/operate_side_button_background"
                android:contentDescription="@string/operate_open_sql_overlay_cd"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_ui_sliders"
                android:tint="@color/cwcn_title" />

            <ImageButton
                android:id="@+id/sideTemplateButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/operate_side_button_background"
                android:contentDescription="@string/operate_open_template_overlay_cd"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/icon_side_template"
                android:tint="@color/cwcn_title" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
