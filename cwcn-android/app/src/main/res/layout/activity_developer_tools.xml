<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cwcn_screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/developer_tools_title"
            android:textColor="@color/cwcn_title"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/developer_tools_subtitle"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/versionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/cwcn_accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/developer_tools_back" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/developer_tools_mode_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/developerModeStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <Button
                android:id="@+id/toggleDeveloperModeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/developer_tools_toggle_on" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/toolsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bootstrap_panel_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/developer_tools_tools_title"
                android:textColor="@color/cwcn_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/toolsHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp" />

            <Button
                android:id="@+id/openRxDebugButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/developer_tools_open_rx_debug" />

            <TextView
                android:id="@+id/latestTraceStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bootstrap_field_background"
                android:lineSpacingExtra="3dp"
                android:padding="12dp"
                android:text="@string/developer_tools_latest_trace_empty"
                android:textColor="@color/cwcn_body"
                android:textSize="13sp" />

            <Button
                android:id="@+id/openLatestTraceReplayButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/developer_tools_open_latest_trace_replay" />

            <Button
                android:id="@+id/openTxConsoleButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/developer_tools_open_tx_console" />

            <Button
                android:id="@+id/openRigBenchButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/developer_tools_open_rig_bench" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
