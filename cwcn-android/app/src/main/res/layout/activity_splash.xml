<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_window_background"
    android:clickable="true"
    android:focusable="true">

    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="top|end"
        android:background="@drawable/splash_orb_primary"
        android:translationX="64dp"
        android:translationY="-48dp" />

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/splash_orb_secondary"
        android:translationX="-54dp"
        android:translationY="40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <LinearLayout
            android:id="@+id/brandPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/splash_panel_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="156dp"
                android:layout_height="156dp"
                android:background="@drawable/bootstrap_panel_background"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/logoImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/app_name"
                    android:src="@mipmap/ic_launcher" />
            </FrameLayout>

            <TextView
                android:id="@+id/buildChannelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bootstrap_panel_background"
                android:paddingStart="14dp"
                android:paddingTop="6dp"
                android:paddingEnd="14dp"
                android:paddingBottom="6dp"
                android:textColor="@color/cwcn_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/appTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="CWCN"
                android:textColor="@color/cwcn_title"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/appSubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Continuous Wave Contact Notebook"
                android:textColor="@color/cwcn_accent"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/authorLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Author Callsign"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/authorCallsignText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/cwcn_title"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/metaPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bootstrap_panel_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cwcn_body"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buildTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/cwcn_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/enterButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:minHeight="52dp"
            android:text="Enter CWCN" />

        <TextView
            android:id="@+id/splashHintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tap anywhere or wait a moment"
            android:textColor="@color/cwcn_subtitle"
            android:textSize="12sp" />
    </LinearLayout>

</FrameLayout>
