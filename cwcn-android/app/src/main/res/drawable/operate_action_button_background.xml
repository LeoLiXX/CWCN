<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <solid android:color="@color/cwcn_soft_button_active_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/cwcn_soft_button_active_stroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <solid android:color="@color/cwcn_soft_button_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/cwcn_soft_button_stroke" />
        </shape>
    </item>
</selector>
