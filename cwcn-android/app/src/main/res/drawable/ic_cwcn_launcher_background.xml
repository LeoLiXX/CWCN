<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:centerColor="@color/cwcn_icon_bg_mid"
                android:endColor="@color/cwcn_icon_bg_deep"
                android:startColor="@color/cwcn_icon_bg_edge" />
        </shape>
    </item>
    <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <stroke
                android:width="1dp"
                android:color="#167DEDE0" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <size android:width="180dp" android:height="180dp" />
            <gradient
                android:centerColor="#5A1E5E6E"
                android:endColor="#00123540"
                android:gradientRadius="120dp"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
