<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <solid android:color="#382118" />
            <stroke
                android:width="1dp"
                android:color="@color/cwcn_warning" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <solid android:color="#2A1812" />
            <stroke
                android:width="1dp"
                android:color="#88FF9C6A" />
        </shape>
    </item>
</selector>
